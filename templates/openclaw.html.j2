<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>OVERHEAR Daily Briefing — {{ date }}</title>
  <style>
    body { font-family: system-ui, sans-serif; line-height:1.45; color:#111; max-width:720px; margin:0 auto; padding:20px 16px; }
    h1 { font-size:1.2rem; margin-bottom:0.2rem; }
    .meta { color:#555; font-size:0.9rem; margin-bottom:1.2rem; }
    h2 { font-size:1rem; margin:1.4rem 0 0.4rem; border-bottom:1px solid #ccc; padding-bottom:4px; }
    h3 { font-size:0.95rem; margin:1rem 0 0.35rem; color:#333; }
    ul { margin:0.3rem 0 0.8rem; padding-left:1.1rem; }
    li { margin-bottom:0.85rem; }
    a { color:#0b5cab; }
    .sum { font-size:0.88rem; color:#444; margin:0.25rem 0; }
    .why { font-size:0.82rem; color:#555; margin:0.2rem 0; }
    .skip { color:#777; font-style:italic; }
    footer { margin-top:1.5rem; font-size:0.8rem; color:#888; }
  </style>
</head>
<body>
  <h1>OVERHEAR Daily Briefing</h1>
  <p class="meta">{{ date }} · {{ item_count }} link(s)</p>

  <h2>📋 Daily Briefing</h2>
  <h3>Culture Central</h3>
  {% if view.culture_central %}
  <ul>
    {% for item in view.culture_central %}
    <li>
      <a href="{{ item.url }}">{{ item.title }}</a>
      <p class="sum">{{ display_summary(item) }}</p>
      <p class="why"><strong>Why:</strong> {{ why.get(item.category, "Sector signal.") }}</p>
    </li>
    {% endfor %}
  </ul>
  {% else %}<p class="skip">Nothing new in this block.</p>{% endif %}

  <h3>CHWA</h3>
  {% if view.chwa %}
  <ul>
    {% for item in view.chwa %}
    <li>
      <a href="{{ item.url }}">{{ item.title }}</a>
      <p class="sum">{{ display_summary(item) }}</p>
      <p class="why"><strong>Why:</strong> {{ why.get(item.category, "Creative health context.") }}</p>
    </li>
    {% endfor %}
  </ul>
  {% else %}<p class="skip">Nothing new in this block.</p>{% endif %}

  <h2>🎧 OVERHEAR Digest</h2>

  <h3>⚡ Time-Sensitive</h3>
  {% if view.time_sensitive %}
  <ul>
    {% for item in view.time_sensitive %}
    <li>
      <a href="{{ item.url }}">{{ item.title }}</a>
      {% if item.deadline_at %}<span> — deadline <strong>{{ item.deadline_at.strftime("%d %B %Y") }}</strong></span>{% endif %}
      <p class="sum">{{ display_summary(item) }}</p>
      <p class="why"><strong>Why:</strong> {{ why.get("time_sensitive", "") }}</p>
    </li>
    {% endfor %}
  </ul>
  {% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>💰 Funding &amp; Opportunities</h3>
  {% if view.funding %}<ul>{% for item in view.funding %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("funding_opportunities", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>🏙️ Birmingham &amp; Black Country Watch</h3>
  {% if view.birmingham %}<ul>{% for item in view.birmingham %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("birmingham_black_country", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>🎧 Audio &amp; Walking Arts</h3>
  {% if view.audio %}<ul>{% for item in view.audio %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("audio_walking_arts", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>✍️ Poetry &amp; Place</h3>
  {% if view.poetry %}<ul>{% for item in view.poetry %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("poetry_place", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>🧐 Arts &amp; Health</h3>
  {% if view.arts_health %}<ul>{% for item in view.arts_health %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("arts_health", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>🌐 Network &amp; Other</h3>
  {% if view.network %}<ul>{% for item in view.network %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("network_other", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <h3>🧐 Worth Checking</h3>
  {% if view.worth_checking %}<ul>{% for item in view.worth_checking %}
    <li><a href="{{ item.url }}">{{ item.title }}</a><p class="sum">{{ display_summary(item) }}</p>
    <p class="why"><strong>Why:</strong> {{ why.get("worth_checking", "") }}</p></li>
  {% endfor %}</ul>{% else %}<p class="skip">Nothing in this block.</p>{% endif %}

  <footer><a href="https://theoverhear.app">theoverhear.app</a></footer>
</body>
</html>
