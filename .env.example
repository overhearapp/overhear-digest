# Copy to .env for local runs (never commit .env)

# Digest recipients (comma-separated allowed)
DIGEST_TO_EMAIL=

# Sender (verified in Mailjet or Resend)
EMAIL_FROM="OVERHEAR Digest <>"
# Legacy alias (optional if EMAIL_FROM is set)
# RESEND_FROM="OVERHEAR Digest <digest@yourdomain.com>"

# Mailjet — https://www.mailjet.com/ (API Key + Secret Key from account)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# Or Resend — https://resend.com (only if not using Mailjet)
# RESEND_API_KEY=re_xxxxxxxx

# auto | mailjet | resend (default auto: Mailjet if both Mailjet keys set, else Resend)
# EMAIL_PROVIDER=auto

# Web search (optional; match search.provider in config/digest.yaml)
BRAVE_API_KEY=
# TAVILY_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# Optional
# DIGEST_CONFIG=config/digest.yaml
# Override path for 7-day URL history JSON (default data/digest_history.json)
# DIGEST_HISTORY_PATH=data/digest_history.json
